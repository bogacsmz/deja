# LLM auth for the Claude Agent SDK. Déjà uses your Claude Max/Pro SUBSCRIPTION, not a paid API
# key: run `claude setup-token` once (opens a browser) and paste the token here. This is the
# supported headless/SDK auth for the subscription.
CLAUDE_CODE_OAUTH_TOKEN=YOUR_CLAUDE_CODE_OAUTH_TOKEN
# Alternative (per-token API billing) — only if you prefer it over the subscription:
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Phase 2 (RTS recall): a Slack USER token (xoxp-…) with search:read.public (+ chat:write,
# channels:read, channels:history for seeding). RTS from OUTSIDE the Slack client requires a
# user token — a bot token will not work. Copy the "User OAuth Token" from the app's
# OAuth & Permissions page after installing with the user scopes.
SLACK_USER_TOKEN=YOUR_SLACK_USER_TOKEN

# Optional: which channel scripts/seed_deja.py writes the demo thread into (default: eng).
# DEJA_SEED_CHANNEL=eng

# Optional, uncomment and set when running without the Slack CLI (python3 app.py).
# SLACK_APP_TOKEN=YOUR_SLACK_APP_TOKEN
# SLACK_BOT_TOKEN=YOUR_SLACK_BOT_TOKEN

# Required for OAuth (app_oauth.py). Set your app's OAuth credentials.
# SLACK_CLIENT_ID=YOUR_SLACK_CLIENT_ID
# SLACK_CLIENT_SECRET=YOUR_SLACK_CLIENT_SECRET
# SLACK_SIGNING_SECRET=YOUR_SLACK_SIGNING_SECRET
# SLACK_REDIRECT_URI=https://YOUR_NGROK_SUBDOMAIN.ngrok-free.app/slack/oauth_redirect

# Optional, uncomment and set when using a custom Slack instance.
# SLACK_API_URL=YOUR_SLACK_API_URL
