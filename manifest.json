{
  "display_information": {
    "name": "Déjà"
  },
  "features": {
    "agent_view": {
      "agent_description": "Déjà surfaces the concrete past thread your team already had on a decision, so you stop re-litigating what you already discussed. (Phase 1 skeleton — powered by Legibright.)",
      "suggested_prompts": []
    },
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "Deja",
      "always_online": true
    }
  },
  "oauth_config": {
    "redirect_urls": [
      "https://deja-production.up.railway.app/slack/oauth_redirect"
    ],
    "scopes": {
      "user": [
        "search:read",
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "mpim:history",
        "users:read",
        "search:read.public",
        "search:read.private",
        "search:read.mpim",
        "search:read.im",
        "search:read.files",
        "search:read.users",
        "chat:write",
        "canvases:read",
        "canvases:write",
        "users:read.email"
      ],
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "reactions:write",
        "reactions:read",
        "users:read",
        "assistant:write",
        "mcp:connect",
        "users:read.email"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://deja-production.up.railway.app/slack/events",
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://deja-production.up.railway.app/slack/events"
    },
    "is_mcp_enabled": true,
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  },
  "mcp_servers": {
    "Deja": {
      "url": "https://deja-production.up.railway.app/mcp",
      "auth_type": "slack_identity_auth"
    }
  }
}
